<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ecommerce Coder Backend I</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-light">
    
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/products">Mi Tienda</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/products">Productos</a>
                <a id="nav-cart-link" class="nav-link" href="#">Mi Carrito</a>
            </div>
        </div>
    </nav>

    <main class="container">
        {{{body}}}
    </main>

    <!-- SweetAlert2 & Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const getCartId = async () => {
            // Intentar obtener el ID del localStorage
            let cartId = localStorage.getItem("cartId");

            // Si no existe, pedirle al servidor que cree uno nuevo
            if (!cartId) {
                try {
                    const response = await fetch("/api/carts", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ owner: "guest" }) 
                    });
                    
                    const data = await response.json();
                    
                    if (data.payload && data.payload._id) {
                    cartId = data.payload._id;
                    localStorage.setItem("cartId", cartId);
                    console.log("Nuevo carrito creado:", cartId);
                    }
                } catch (error) {
                    console.error("Error al crear el carrito:", error);
                }
            }
            
            return cartId;
        };

        // Función global para agregar productos (usada en los botones de index.handlebars)
        const addToCart = async (productId) => {
            const cid = await getCartId();
            if (!cid) return Swal.fire("Error", "No se pudo gestionar el carrito", "error");

            try {
            const response = await fetch(`/api/carts/${cid}/products/${productId}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" }
            });

            if (response.ok) {
                Swal.fire({
                icon: 'success',
                title: 'Producto añadido',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2000
                });
            }
            } catch (error) {
            Swal.fire("Error", "No se pudo agregar el producto", "error");
            }
        };

        // Actualizar el link de "Mi Carrito" en el Navbar dinámicamente
        document.addEventListener("DOMContentLoaded", async () => {
            const cid = await getCartId();
            const cartLink = document.getElementById("nav-cart-link");
            if (cartLink && cid) {
                cartLink.href = `/carts/${cid}`;
            }
        });
    </script>
</body>
</html>
