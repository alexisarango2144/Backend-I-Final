<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="display-5">Catálogo de Productos</h1>
    </div>
    <!-- Filtros rápidos -->
    <div class="col-md-6 text-end">
        <div class="btn-group">
            <a href="/products?sort=asc" class="btn btn-outline-secondary btn-sm">Precio ↑</a>
            <a href="/products?sort=desc" class="btn btn-outline-secondary btn-sm">Precio ↓</a>
            <a href="/products?query=available" class="btn btn-outline-success btn-sm">Disponibles</a>
        </div>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    {{#each products}}
    <div class="col">
        <div class="card h-100 shadow-sm">
            <img src="{{this.thumbnails.[0]}}" class="card-img-top" alt="{{this.title}}" style="height: 200px; object-fit: cover;">
            <div class="card-body">
                <h5 class="card-title text-truncate">{{this.title}}</h5>
                <p class="card-text text-muted small">{{this.category}}</p>
                <h4 class="text-primary">${{this.price}}</h4>
                {{#if this.stock}}
                    <p class="small">Stock: {{this.stock}}</p>
                {{else}}
                    <p class="small text-danger fw-bold">Agotado</p>
                {{/if}}
            </div>
            <div class="card-footer bg-white border-top-0 d-grid gap-2">
                {{#if this.stock}}
                    <button onclick="addToCart('{{this._id}}')" class="btn btn-primary">Agregar al Carrito</button>
                {{else}}
                    <button class="btn btn-secondary" disabled>Sin Stock</button>
                {{/if}}
                <a href="/products/{{this._id}}" class="btn btn-outline-secondary btn-sm">Ver detalles</a>
            </div>
        </div>
    </div>
    {{/each}}
</div>

<!-- Paginación -->
<nav class="mt-5">
    <ul class="pagination justify-content-center">
        <li class="page-item {{#unless hasPrevPage}}disabled{{/unless}}">
            <a class="page-link" href="{{prevLink}}">Anterior</a>
        </li>
        {{#each pages}}
        <li class="page-item {{#if this.isCurrent}}active{{/if}}">
            <a class="page-link" href="{{this.link}}">{{this.number}}</a>
        </li>
        {{/each}}
        <li class="page-item {{#unless hasNextPage}}disabled{{/unless}}">
            <a class="page-link" href="{{nextLink}}">Siguiente</a>
        </li>
    </ul>
</nav>
